#include <iostream>
#include <cmath>

int main() {
    const double left = -25.0, right = 25.0;
    int n = 1000000;
    double step = (right - left) / n;
    double area = 0.0;
    
    for (int i = 0; i < n; ++i) {
        double x = left + i * step;
        area += (25.0 - std::abs(x)) * step;
    }
    
    printf("Площадь: %.10f\n", area);
    return 0;
}
